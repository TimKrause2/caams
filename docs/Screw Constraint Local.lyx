\begin_layout Standard
\begin_inset Formula 
\begin{align}
\mathbf{\Phi} & =\mathbf{u}^{,T}_{s}\mathbf{u}^{,}_{j}\nonumber \\
\dot{\mathbf{\Phi}} & =\mathbf{u}^{,T}_{s}\dot{\mathbf{u}}^{,}_{j}+\mathbf{u}^{,T}_{j}\dot{\mathbf{u}}^{,}_{s}\nonumber \\
\ddot{\mathbf{\Phi}} & =\mathbf{u}^{,T}_{s}\ddot{\mathbf{u}}^{,}_{j}+\mathbf{u}^{,T}_{j}\ddot{\mathbf{u}}^{,}_{s}+2\dot{\mathbf{u}}^{,T}_{s}\dot{\mathbf{u}}^{,}_{j}\label{eq:phi_ddot}
\end{align}

\end_inset


\end_layout

\begin_layout Standard
\begin_inset Formula 
\begin{align}
\mathbf{u}^{,}_{s} & =\mathbf{A}_{s}\mathbf{u}^{,}_{i}\nonumber \\
\dot{\mathbf{u}}^{,}_{s} & =\dot{\mathbf{A}}_{s}\mathbf{u}^{,}_{i}\nonumber \\
\ddot{\mathbf{u}}^{,}_{s} & =\ddot{\mathbf{A}}_{s}\mathbf{u}^{,}_{i}\label{eq:u_s_ddot}
\end{align}

\end_inset


\begin_inset Formula 
\begin{align}
\mathbf{u}^{,}_{j} & =\mathbf{A}^{T}_{i}\mathbf{A}_{j}\mathbf{u}^{,,}_{j}\nonumber \\
\dot{\mathbf{u}}^{,}_{j} & =\dot{\mathbf{A}}^{T}_{i}\mathbf{A}_{j}\mathbf{u}^{,,}_{j}+\mathbf{A}^{T}_{i}\dot{\mathbf{A}}_{j}\mathbf{u}^{,,}_{j}\nonumber \\
\ddot{\mathbf{u}}^{,}_{j} & =\ddot{\mathbf{A}}^{T}_{i}\mathbf{A}_{j}\mathbf{u}^{,,}_{j}+\mathbf{A}^{T}_{i}\ddot{\mathbf{A}}_{j}\mathbf{u}^{,,}_{j}+2\dot{\mathbf{A}}^{T}_{i}\dot{\mathbf{A}}_{j}\mathbf{u}^{,,}_{j}\label{eq:u_j_ddot}
\end{align}

\end_inset


\end_layout

\begin_layout Standard
\begin_inset Formula 
\[
\mathbf{p}_{s}=\left[\begin{array}{c}
\cos\left(\frac{\beta}{2}l\right)\\
\sin\left(\frac{\beta}{2}l\right)\mathbf{a}^{,}_{i}
\end{array}\right]
\]

\end_inset


\begin_inset Formula 
\[
\dot{\mathbf{p}}_{s}=\left[\begin{array}{c}
-\frac{\beta}{2}\sin\left(\frac{\beta}{2}l\right)\dot{l}\\
\frac{\beta}{2}\cos\left(\frac{\beta}{2}l\right)\dot{l}\mathbf{a}^{,}_{i}
\end{array}\right]=\mathbf{k}_{1}\dot{l}
\]

\end_inset


\begin_inset Formula 
\begin{equation}
\ddot{\mathbf{p}}_{s}=\left[\begin{array}{c}
-\frac{\beta}{2}\sin\left(\frac{\beta}{2}l\right)\ddot{l}-\frac{\beta^{2}}{4}\cos\left(\frac{\beta}{2}l\right)\dot{l}^{2}\\
\frac{\beta}{2}\cos\left(\frac{\beta}{2}l\right)\ddot{l}\mathbf{a}^{,}_{i}-\frac{\beta^{2}}{4}\sin\left(\frac{\beta}{2}l\right)\dot{l}^{2}\mathbf{a}^{,}_{i}
\end{array}\right]=\mathbf{k}_{1}\ddot{l}+\mathbf{k}_{2}\dot{l}^{2}\label{eq:p_s_ddot}
\end{equation}

\end_inset


\end_layout

\begin_layout Standard
\begin_inset Formula 
\begin{align}
l & =\mathbf{a}^{,T}_{i}\mathbf{d}^{,}\nonumber \\
\dot{l} & =\mathbf{a}^{,T}_{i}\dot{\mathbf{d}}^{,}\nonumber \\
\ddot{l} & =\mathbf{a}^{,T}_{i}\ddot{\mathbf{d}}^{,}\label{eq:l_ddot}
\end{align}

\end_inset


\end_layout

\begin_layout Standard
\begin_inset Formula 
\begin{align}
\mathbf{d}^{,} & =\mathbf{s}^{,}_{j}-\mathbf{s}^{,}_{i}\nonumber \\
 & =\mathbf{A}^{T}_{i}\left(\mathbf{r}_{j}+\mathbf{A}_{j}\mathbf{s}^{,,}_{j}-\mathbf{r}_{i}\right)-\mathbf{s}^{,}_{i}\nonumber \\
 & =\mathbf{A}^{T}_{i}\mathbf{r}_{j}+\mathbf{A}^{T}_{i}\mathbf{A}_{j}\mathbf{s}^{,,}_{j}-\mathbf{A}^{T}_{i}\mathbf{r}_{i}-\mathbf{s}^{,}_{i}\nonumber \\
\dot{\mathbf{d}}^{,} & =\dot{\mathbf{A}}^{T}_{i}\mathbf{r}_{j}+\mathbf{A}^{T}_{i}\dot{\mathbf{r}}_{j}+\dot{\mathbf{A}}^{T}_{i}\mathbf{A}_{j}\mathbf{s}^{,,}_{j}+\mathbf{A}^{T}_{i}\dot{\mathbf{A}}_{j}\mathbf{s}^{,,}_{j}-\dot{\mathbf{A}}^{T}_{i}\mathbf{r}_{i}-\mathbf{A}^{T}_{i}\dot{\mathbf{r}}_{i}\nonumber \\
\ddot{\mathbf{d}}^{,} & =\ddot{\mathbf{A}}^{T}_{i}\mathbf{r}_{j}+\mathbf{A}^{T}_{i}\ddot{\mathbf{r}}_{j}+2\dot{\mathbf{A}}^{T}_{i}\dot{\mathbf{r}}_{j}+\ddot{\mathbf{A}}^{T}_{i}\mathbf{A}_{j}\mathbf{s}^{,,}_{j}+\mathbf{A}^{T}_{i}\ddot{\mathbf{A}}_{j}\mathbf{s}^{,,}_{j}+2\dot{\mathbf{A}}^{T}_{i}\dot{\mathbf{A}}_{j}\mathbf{s}^{,,}_{j}-\ddot{\mathbf{A}}^{T}_{i}\mathbf{r}_{i}-\mathbf{A}^{T}_{i}\ddot{\mathbf{r}}_{i}-2\dot{\mathbf{A}}^{T}_{i}\dot{\mathbf{r}}_{i}\nonumber \\
 & =\ddot{\mathbf{A}}^{T}_{i}\left(\mathbf{r}_{j}+\mathbf{s}_{j}-\mathbf{r}_{i}\right)+\mathbf{A}^{T}_{i}\ddot{\mathbf{A}}_{j}\mathbf{s}^{,,}_{j}+\mathbf{A}^{T}_{i}\ddot{\mathbf{r}}_{j}-\mathbf{A}^{T}_{i}\ddot{\mathbf{r}}_{i}+2\dot{\mathbf{A}}^{T}_{i}\dot{\mathbf{A}}_{j}\mathbf{s}^{,,}_{j}+2\dot{\mathbf{A}}^{T}_{i}\dot{\mathbf{r}}_{j}-2\dot{\mathbf{A}}^{T}_{i}\dot{\mathbf{r}}_{i}\nonumber \\
 & =\ddot{\mathbf{A}}^{T}_{i}\mathbf{\varDelta}+\mathbf{A}^{T}_{i}\ddot{\mathbf{A}}_{j}\mathbf{s}^{,,}_{j}+\mathbf{A}^{T}_{i}\ddot{\mathbf{r}}_{j}-\mathbf{A}^{T}_{i}\ddot{\mathbf{r}}_{i}+2\dot{\mathbf{A}}^{T}_{i}\dot{\mathbf{A}}_{j}\mathbf{s}^{,,}_{j}+2\dot{\mathbf{A}}^{T}_{i}\dot{\mathbf{r}}_{j}-2\dot{\mathbf{A}}^{T}_{i}\dot{\mathbf{r}}_{i}\label{eq:d_p_ddot}
\end{align}

\end_inset


\end_layout

