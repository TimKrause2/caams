\begin_layout Standard
\begin_inset Formula 
\begin{align*}
\ddot{\mathbf{\Phi}} & =\mathbf{u}^{,T}_{s}\ddot{\mathbf{A}}^{T}_{i}\mathbf{A}_{j}\mathbf{u}^{,,}_{j}+\mathbf{u}^{,T}_{s}\mathbf{A}^{T}_{i}\ddot{\mathbf{A}}_{j}\mathbf{u}^{,,}_{j}+2\mathbf{u}^{,T}_{s}\dot{\mathbf{A}}^{T}_{i}\dot{\mathbf{A}}_{j}\mathbf{u}^{,,}_{j}+\mathbf{u}^{,T}_{j}\ddot{\mathbf{A}}_{s}\mathbf{u}^{,}_{i}+2\dot{\mathbf{u}}^{,T}_{s}\dot{\mathbf{u}}^{,}_{j}\\
 & =\mathbf{u}^{,T}_{s}\ddot{\mathbf{A}}^{T}_{i}\mathbf{u}_{j}+\mathbf{u}^{,T}_{s}\mathbf{A}^{T}_{i}\ddot{\mathbf{A}}_{j}\mathbf{u}^{,,}_{j}+\mathbf{u}^{,T}_{j}\ddot{\mathbf{A}}_{s}\mathbf{u}^{,}_{i}+2\dot{\mathbf{u}}^{,T}_{s}\dot{\mathbf{u}}^{,}_{j}+2\mathbf{u}^{,T}_{s}\dot{\mathbf{A}}^{T}_{i}\dot{\mathbf{A}}_{j}\mathbf{u}^{,,}_{j}
\end{align*}

\end_inset


\end_layout

\begin_layout Standard
Equations from the book to isolate the accelerations and the modified Jacobian:
\end_layout

\begin_layout Standard
\begin_inset Formula 
\begin{align*}
\ddot{\mathbf{A}}\mathbf{u} & =2\dot{\mathbf{G}}\dot{\mathbf{L}}^{T}\mathbf{u}+2\mathbf{G}\overset{-}{\mathbf{u}}\ddot{\mathbf{p}}\\
\ddot{\mathbf{A}}^{T}\mathbf{u} & =2\dot{\mathbf{L}}\dot{\mathbf{G}}^{T}\mathbf{u}+2\mathbf{L}\overset{+}{\mathbf{u}}\ddot{\mathbf{p}}
\end{align*}

\end_inset


\end_layout

\begin_layout Standard
\begin_inset Formula 
\begin{align*}
\ddot{\mathbf{\Phi}} & =2\mathbf{u}^{,T}_{s}\dot{\mathbf{L}}_{i}\dot{\mathbf{G}}^{T}_{i}\mathbf{u}_{j}+2\mathbf{u}^{,T}_{s}\mathbf{L}_{i}\overset{+}{\mathbf{u}}_{j}\ddot{\mathbf{p}}_{i}+2\mathbf{u}^{,T}_{s}\mathbf{A}^{T}_{i}\dot{\mathbf{G}}_{j}\dot{\mathbf{L}}^{T}_{j}\mathbf{u}^{,,}_{j}+2\mathbf{u}^{,T}_{s}\mathbf{A}^{T}_{i}\mathbf{G}_{j}\overset{-}{\mathbf{u}}^{,,}_{j}\ddot{\mathbf{p}}_{j}+2\mathbf{u}^{,T}_{j}\dot{\mathbf{G}}_{s}\dot{\mathbf{L}}^{T}_{s}\mathbf{u}^{,}_{i}+2\mathbf{u}^{,T}_{j}\mathbf{G}_{s}\overset{-}{\mathbf{u}_{i}}^{,}\ddot{\mathbf{p}}_{s}\\
 & +2\dot{\mathbf{u}}^{,T}_{s}\dot{\mathbf{u}}^{,}_{j}+2\mathbf{u}^{,T}_{s}\dot{\mathbf{A}}^{T}_{i}\dot{\mathbf{A}}_{j}\mathbf{u}^{,,}_{j}
\end{align*}

\end_inset


\end_layout

\begin_layout Standard
Rearranging to isolate the terms dependent on accelerations:
\end_layout

\begin_layout Standard
\begin_inset Formula 
\begin{equation}
2\mathbf{u}^{,T}_{s}\mathbf{L}_{i}\overset{+}{\mathbf{u}}_{j}\ddot{\mathbf{p}}_{i}+2\mathbf{u}^{,T}_{s}\mathbf{A}^{T}_{i}\mathbf{G}_{j}\overset{-}{\mathbf{u}}^{,,}_{j}\ddot{\mathbf{p}}_{j}+2\mathbf{u}^{,T}_{j}\mathbf{G}_{s}\overset{-}{\mathbf{u}_{i}}^{,}\ddot{\mathbf{p}}_{s}=\mathbf{\gamma}\label{eq:phi_acceleration}
\end{equation}

\end_inset


\end_layout

\begin_layout Standard
\begin_inset Formula 
\[
\mathbf{\gamma=}-2\mathbf{u}^{,T}_{s}\dot{\mathbf{L}}_{i}\dot{\mathbf{G}}^{T}_{i}\mathbf{u}_{j}-2\mathbf{u}^{,T}_{s}\mathbf{A}^{T}_{i}\dot{\mathbf{G}}_{j}\dot{\mathbf{L}}^{T}_{j}\mathbf{u}^{,,}_{j}-2\mathbf{u}^{,T}_{j}\dot{\mathbf{G}}_{s}\dot{\mathbf{L}}^{T}_{s}\mathbf{u}^{,}_{i}-2\dot{\mathbf{u}}^{,T}_{s}\dot{\mathbf{u}}^{,}_{j}-2\mathbf{u}^{,T}_{s}\dot{\mathbf{A}}^{T}_{i}\dot{\mathbf{A}}_{j}\mathbf{u}^{,,}_{j}
\]

\end_inset


\end_layout

\begin_layout Standard
Two modified Jacobians can be found from equation 
\begin_inset CommandInset ref
LatexCommand ref
reference "eq:phi_acceleration"
plural "false"
caps "false"
noprefix "false"
nolink "false"
tuple "list"

\end_inset

.
\end_layout

\begin_layout Standard
\begin_inset Formula 
\begin{align*}
\mathbf{\Phi}^{,}_{\mathbf{r_{i}}} & =\mathbf{0}^{T}\\
\mathbf{\Phi}^{,}_{\mathbf{p}_{i}} & =2\mathbf{u}^{,T}_{s}\mathbf{L}_{i}\overset{+}{\mathbf{u}}_{j}\\
\mathbf{\Phi}^{,}_{\mathbf{r}_{j}} & =\mathbf{0}^{T}\\
\Phi^{,}_{\mathbf{p}_{j}} & =2\mathbf{u}^{,T}_{s}\mathbf{A}^{T}_{i}\mathbf{G}_{j}\overset{-}{\mathbf{u}}^{,,}_{j}
\end{align*}

\end_inset


\end_layout

\begin_layout Standard
The term dependent on 
\begin_inset Formula $\ddot{\mathbf{p}}_{s}$
\end_inset

 is expanded with the help of equation 
\begin_inset CommandInset ref
LatexCommand ref
reference "eq:p_s_ddot"
plural "false"
caps "false"
noprefix "false"
nolink "false"
tuple "list"

\end_inset

:
\end_layout

\begin_layout Standard
\begin_inset Formula 
\[
2\mathbf{u}^{,T}_{j}\mathbf{G}_{s}\overset{-}{\mathbf{u}_{i}}^{,}\ddot{\mathbf{p}}_{s}=\mathbf{M}\left(\mathbf{k}_{1}\ddot{l}+\mathbf{k}_{2}\dot{l}^{2}\right)=m_{1}\ddot{l}+m_{2}\dot{l}^{2}
\]

\end_inset


\end_layout

\begin_layout Standard
\begin_inset Formula $m_{1}\ddot{l}$
\end_inset

 is expanded with the help of equations 
\begin_inset CommandInset ref
LatexCommand ref
reference "eq:l_ddot,eq:d_p_ddot"
plural "false"
caps "false"
noprefix "false"
nolink "false"
tuple "list"

\end_inset

:
\end_layout

\begin_layout Standard
\begin_inset Formula 
\[
m_{1}\ddot{l}=m_{1}\mathbf{a}^{,T}_{i}\ddot{\mathbf{A}}^{T}_{i}\mathbf{\varDelta}+m_{1}\mathbf{a}^{,T}_{i}\mathbf{A}^{T}_{i}\ddot{\mathbf{A}}_{j}\mathbf{s}^{,,}_{j}+m_{1}\mathbf{a}^{,T}_{i}\mathbf{A}^{T}_{i}\ddot{\mathbf{r}}_{j}-m_{1}\mathbf{a}^{,T}_{i}\mathbf{A}^{T}_{i}\ddot{\mathbf{r}}_{i}+2m_{1}\mathbf{a}^{,T}_{i}\dot{\mathbf{A}}^{T}_{i}\dot{\mathbf{A}}_{j}\mathbf{s}^{,,}_{j}+2m_{1}\mathbf{a}^{,T}_{i}\dot{\mathbf{A}}^{T}_{i}\dot{\mathbf{r}}_{j}-2m_{1}\mathbf{a}^{,T}_{i}\dot{\mathbf{A}}^{T}_{i}\dot{\mathbf{r}}_{i}
\]

\end_inset


\end_layout

\begin_layout Standard
Equations from the book are used once again to find the dependence on the Euler parameter accelerations.
\end_layout

\begin_layout Standard
\begin_inset Formula 
\begin{align*}
m_{1}\ddot{l} & =2m_{1}\mathbf{a}^{,T}_{i}\dot{\mathbf{L}}_{i}\dot{\mathbf{G}}^{T}_{i}\varDelta+2m_{1}\mathbf{a}^{,T}_{i}\mathbf{L}_{i}\overset{+}{\mathbf{\varDelta}}\ddot{\mathbf{p}}_{i}+2m_{1}\mathbf{a}^{,T}_{i}\mathbf{A}^{T}_{i}\dot{\mathbf{G}}_{j}\dot{\mathbf{L}}^{T}_{j}\mathbf{s}^{,,}_{j}+2m_{1}\mathbf{a}^{,T}_{i}\mathbf{A}^{T}_{i}\mathbf{G}_{j}\overset{-}{\mathbf{s}_{j}}^{,,}\ddot{\mathbf{p}}_{j}\\
 & +m_{1}\mathbf{a}^{,T}_{i}\mathbf{A}^{T}_{i}\ddot{\mathbf{r}}_{j}-m_{1}\mathbf{a}^{,T}_{i}\mathbf{A}^{T}_{i}\ddot{\mathbf{r}}_{i}+2m_{1}\mathbf{a}^{,T}_{i}\dot{\mathbf{A}}^{T}_{i}\dot{\mathbf{A}}_{j}\mathbf{s}^{,,}_{j}+2m_{1}\mathbf{a}^{,T}_{i}\dot{\mathbf{A}}^{T}_{i}\dot{\mathbf{r}}_{j}-2m_{1}\mathbf{a}^{,T}_{i}\dot{\mathbf{A}}^{T}_{i}\dot{\mathbf{r}}_{i}
\end{align*}

\end_inset


\end_layout

\begin_layout Standard
Rearranging to put all the terms dependent on accelerations on the left hand side and the constant terms on the right hand side.
\end_layout

\begin_layout Standard
\begin_inset Formula 
\begin{equation}
2m_{1}\mathbf{a}^{,T}_{i}\mathbf{L}_{i}\overset{+}{\mathbf{\varDelta}}\ddot{\mathbf{p}}_{i}+2m_{1}\mathbf{a}^{,T}_{i}\mathbf{A}^{T}_{i}\mathbf{G}_{j}\overset{-}{\mathbf{s}_{j}}^{,,}\ddot{\mathbf{p}}_{j}+m_{1}\mathbf{a}^{,T}_{i}\mathbf{A}^{T}_{i}\ddot{\mathbf{r}}_{j}-m_{1}\mathbf{a}^{,T}_{i}\mathbf{A}^{T}_{i}\ddot{\mathbf{r}}_{i}=\mathbf{\gamma}\label{eq:m1_l_ddot_acceleration}
\end{equation}

\end_inset


\end_layout

\begin_layout Standard
\begin_inset Formula 
\[
\mathbf{\gamma}^{l}=-2m_{1}\mathbf{a}^{,T}_{i}\dot{\mathbf{L}}_{i}\dot{\mathbf{G}}^{T}_{i}\varDelta-2m_{1}\mathbf{a}^{,T}_{i}\mathbf{A}^{T}_{i}\dot{\mathbf{G}}_{j}\dot{\mathbf{L}}^{T}_{j}\mathbf{s}^{,,}_{j}-2m_{1}\mathbf{a}^{,T}_{i}\dot{\mathbf{A}}^{T}_{i}\dot{\mathbf{A}}_{j}\mathbf{s}^{,,}_{j}-2m_{1}\mathbf{a}^{,T}_{i}\dot{\mathbf{A}}^{T}_{i}\dot{\mathbf{r}}_{j}+2m_{1}\mathbf{a}^{,T}_{i}\dot{\mathbf{A}}^{T}_{i}\dot{\mathbf{r}}_{i}-m_{2}\dot{l}^{2}
\]

\end_inset


\end_layout

\begin_layout Standard
Equation 
\begin_inset CommandInset ref
LatexCommand ref
reference "eq:m1_l_ddot_acceleration"
plural "false"
caps "false"
noprefix "false"
nolink "false"
tuple "list"

\end_inset

 reveals the modified Jacobians:
\end_layout

\begin_layout Standard
\begin_inset Formula 
\begin{align*}
\left(m_{1}\ddot{l}\right)_{\mathbf{r}_{i}} & =-m_{1}\mathbf{a}^{,T}_{i}\mathbf{A}^{T}_{i}\\
\left(m_{1}\ddot{l}\right)_{\mathbf{p}_{i}} & =2m_{1}\mathbf{a}^{,T}_{i}\mathbf{L}_{i}\overset{+}{\mathbf{\varDelta}}\\
\left(m_{1}\ddot{l}\right)_{\mathbf{r}_{j}} & =m_{1}\mathbf{a}^{,T}_{i}\mathbf{A}^{T}_{i}\\
\left(m_{1}\ddot{l}\right)_{\mathbf{p}_{j}} & =2m_{1}\mathbf{a}^{,T}_{i}\mathbf{A}^{T}_{i}\mathbf{G}_{j}\overset{-}{\mathbf{s}_{j}}^{,,}
\end{align*}

\end_inset


\end_layout

\begin_layout Standard
These Jacobians are combined with the Jacobians obtained from the main constraint equation to yield the modified Jacobians for the constraint.
\end_layout

\begin_layout Standard
\begin_inset Formula 
\begin{align*}
\mathbf{\Phi}_{\mathbf{r_{i}}} & =-m_{1}\mathbf{a}^{,T}_{i}\mathbf{A}^{T}_{i}\\
\mathbf{\Phi}_{\mathbf{p}_{i}} & =2\mathbf{u}^{,T}_{s}\mathbf{L}_{i}\overset{+}{\mathbf{u}}_{j}+2m_{1}\mathbf{a}^{,T}_{i}\mathbf{L}_{i}\overset{+}{\mathbf{\varDelta}}\\
\mathbf{\Phi}_{\mathbf{r}_{j}} & =m_{1}\mathbf{a}^{,T}_{i}\mathbf{A}^{T}_{i}\\
\Phi_{\mathbf{p}_{j}} & =2\mathbf{u}^{,T}_{s}\mathbf{A}^{T}_{i}\mathbf{G}_{j}\overset{-}{\mathbf{u}}^{,,}_{j}+2m_{1}\mathbf{a}^{,T}_{i}\mathbf{A}^{T}_{i}\mathbf{G}_{j}\overset{-}{\mathbf{s}_{j}}^{,,}
\end{align*}

\end_inset


\end_layout

\begin_layout Standard
\begin_inset Formula 
\[
\left[\begin{array}{cccc}
\mathbf{\Phi}_{\mathbf{r_{i}}} & \mathbf{\Phi}_{\mathbf{p}_{i}} & \mathbf{\Phi}_{\mathbf{r}_{j}} & \Phi_{\mathbf{p}_{j}}\end{array}\right]\left[\begin{array}{c}
\ddot{\mathbf{r}}_{i}\\
\ddot{\mathbf{p}}_{i}\\
\ddot{\mathbf{r}}_{j}\\
\ddot{\mathbf{p}}_{j}
\end{array}\right]=\mathbf{\gamma}+\mathbf{\gamma}^{l}
\]

\end_inset


\end_layout

